# Terraform directories
**/.terraform/

# Terraform state files (very sensitive - contains real infra data)
**/*.tfstate
**/*.tfstate.*

# Terraform variable files (may contain secrets)
**/*.tfvars
**/*.tfvars.json

# Terraform lock file (optional - some teams commit this)
**/.terraform.lock.hcl

# Terraform plan output
tfplan
*.tfplan

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash log files
crash.log
crash.*.log

# AWS credentials (just in case)
*.pem
*.key
.env
.env.*